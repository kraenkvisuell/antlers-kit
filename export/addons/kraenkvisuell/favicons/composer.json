{
    "name": "kraenkvisuell/favicons",
    "autoload": {
        "psr-4": {
            "Kraenkvisuell\\Favicons\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kraenkvisuell\\Favicons\\Tests\\": "tests"
        }
    },
    "require": {
        "statamic/cms": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.8"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    },
    "extra": {
        "statamic": {
            "name": "Favicons",
            "description": "Favicons addon"
        },
        "laravel": {
            "providers": [
                "Kraenkvisuell\\Favicons\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
