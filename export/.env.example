MAIL_PORT=2424
MAIL_USERNAME="${APP_NAME}"
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="dummy@kraenk.de"
MAIL_FROM_NAME="Regular John"

CLOUD_ACCESS_KEY_ID=XXXXXXXXXXXX
CLOUD_SECRET_ACCESS_KEY=XXXXXXXXXXXX
CLOUD_DEFAULT_REGION=eu-central
CLOUD_ENDPOINT=https://fsn1.your-objectstorage.com
CLOUD_BUCKET=kraenk-cdn
CLOUD_ROOT=dummy
